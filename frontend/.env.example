# ---------------------------------------------------------------------------
# 백엔드를 다른 PC(또는 같은 LAN의 서버)에서 띄울 때
# ---------------------------------------------------------------------------
# 프론트는 지금 쓰는 머신에서 npm run dev / 배포하고, API만 원격으로 붙입니다.
# 이때 Vite proxy(/api, /oauth2)는 쓰이지 않으므로 반드시 아래처럼 백엔드 전체 URL을 넣습니다.
#
# VITE_API_BASE_URL=http://192.168.0.10:8080
# (또는 도메인) VITE_API_BASE_URL=https://api.example.com
#
# Google 로그인 버튼은 자동으로 위 주소 + /oauth2/authorization/google 로 이동합니다.
# (별도로 쪼개고 싶을 때만) VITE_OAUTH_GOOGLE_URL=http://192.168.0.10:8080/oauth2/authorization/google
#
# 서버(백엔드) 쪽에서도 맞춰야 함:
#   - FRONTEND_BASE_URL = 지금 브라우저로 여는 프론트 주소 (예: http://192.168.0.3:5173)
#   - learningtube.cors.allowed-origins 에 그 프론트 origin 추가
#   - Google 콘솔 승인 리디렉션 URI = http://<백엔드호스트>:8080/login/oauth2/code/google
# ---------------------------------------------------------------------------

# API 베이스 URL (끝에 / 없이)
# 비우면 현재 오리진 기준 상대 경로 → 로컬에서만 Vite proxy로 백엔드(보통 localhost:8080)에 붙음
VITE_API_BASE_URL=

# (선택) OAuth 시작 URL을 API 베이스와 다르게 쓸 때만
# VITE_OAUTH_GOOGLE_URL=
